[
  { "GIID": "1", "GIL": "0", "GIN": "太祖长拳", "GIM": "江湖最普及拳脚，人人都会几招，基础中的基础。" },
  { "GIID": "2", "GIL": "0", "GIN": "通臂掌", "GIM": "手臂伸直如通臂猿猴，力道直来直往。" },
  { "GIID": "3", "GIL": "0", "GIN": "金刚掌", "GIM": "少林入门硬功掌，练至极致可碎石，但威力有限。" },
  { "GIID": "4", "GIL": "0", "GIN": "亮银掌", "GIM": "普通江湖把式，招式闪亮，实则不堪一击。" },
  { "GIID": "5", "GIL": "0", "GIN": "擒拿掌", "GIM": "专门抓拿关节，制服敌人，非致命掌法。" },
  { "GIID": "6", "GIL": "0", "GIN": "黑虎掏心", "GIM": "直奔心窝，简单粗暴，流氓打架常用。" },
  { "GIID": "7", "GIL": "0", "GIN": "撩阴掌", "GIM": "阴损招式，攻人下三路，上不得台面。" },
  { "GIID": "8", "GIL": "0", "GIN": "推云掌", "GIM": "借力打力，推开敌人，无杀伤力。" },
  { "GIID": "9", "GIL": "0", "GIN": "扫叶掌", "GIM": "扫地僧入门功夫，扫去落叶，顺便扫人。" },
  { "GIID": "10", "GIL": "0", "GIN": "震天掌", "GIM": "名字吓人，实则只是拍桌子震天响的虚招。" },
  { "GIID": "11", "GIL": "0", "GIN": "无影掌", "GIM": "掌法慢如蜗牛，却号称无影，欺世盗名之辈。" },
  { "GIID": "12", "GIL": "1", "GIN": "震山掌", "GIM": "掌力雄浑，震动山石，多见于北方门派。" },
  { "GIID": "13", "GIL": "1", "GIN": "破玉掌", "GIM": "刚猛掌法，旨在破开敌人护体罡气或玉石。" },
  { "GIID": "14", "GIL": "1", "GIN": "流云掌", "GIM": "掌法轻柔，如流云般变幻莫测，不着痕迹。" },
  { "GIID": "15", "GIL": "1", "GIN": "断魂掌", "GIM": "阴狠掌法，中掌者魂魄离散，多见于邪派。" },
  { "GIID": "16", "GIL": "1", "GIN": "赤沙掌", "GIM": "西域流派，掌力附带赤色沙砾，伤人皮肉。" },
  { "GIID": "17", "GIL": "1", "GIN": "分水掌", "GIM": "水上功夫，掌力分水，可在水中快速前行。" },
  { "GIID": "18", "GIL": "1", "GIN": "毒砂掌", "GIM": "掌上淬毒，拍中即伤，歹毒无比。" },
  { "GIID": "19", "GIL": "1", "GIN": "开山掌", "GIM": "大开大合，力大势沉，常用于破阵开路。" },
  { "GIID": "20", "GIL": "1", "GIN": "伏虎掌", "GIM": "少林罗汉堂武学，刚猛直率，如猛虎伏地。" },
  { "GIID": "21", "GIL": "1", "GIN": "黑煞掌", "GIM": "掌力阴寒带黑气，中者全身发黑，剧毒无比。" },
  { "GIID": "22", "GIL": "1", "GIN": "百花掌", "GIM": "崆峒或峨眉旁支，招式花哨，多为表演。" },
  { "GIID": "23", "GIL": "2", "GIN": "八卦游身掌", "GIM": "绕圈游走，掌随身发，借力打力。" },
  { "GIID": "24", "GIL": "2", "GIN": "回风掌", "GIM": "华山派基础掌法，掌力回旋，柔中带刚。" },
  { "GIID": "25", "GIL": "2", "GIN": "韦陀掌", "GIM": "少林入门掌法，朴实无华，根基扎实。" },
  { "GIID": "26", "GIL": "2", "GIN": "大韦陀掌", "GIM": "少林进阶掌法，配合金刚杵使用，威力大增。" },
  { "GIID": "27", "GIL": "2", "GIN": "芙蓉掌", "GIM": "掌形如芙蓉花开，招式优美，变化多端。" },
  { "GIID": "28", "GIL": "2", "GIN": "追风掌", "GIM": "掌速极快，如影随形，追击敌人。" },
  { "GIID": "29", "GIL": "2", "GIN": "五罗轻烟掌", "GIM": "掌带轻烟，五指如钩，抓脉拿穴。" },
  { "GIID": "30", "GIL": "2", "GIN": "铁砂掌", "GIM": "外门硬功，练掌如铁，开砖裂石。" },
  { "GIID": "31", "GIL": "2", "GIN": "峨眉掌法", "GIM": "峨眉派基础，柔媚刚劲兼具，巾帼不让须眉。" },
  { "GIID": "32", "GIL": "2", "GIN": "雪山掌", "GIM": "雪山派掌法，掌力寒冷，带有雪域气息。" },
  { "GIID": "33", "GIL": "2", "GIN": "迎风掌", "GIM": "普通掌法，迎风挥击，多用于江湖杂鱼。" },
  { "GIID": "34", "GIL": "3", "GIN": "排云掌", "GIM": "成昆绝学，掌影层层叠叠如排山倒海。" },
  { "GIID": "35", "GIL": "3", "GIN": "劈空掌", "GIM": "以空掌伤人，掌风凌厉，隔空取物。" },
  { "GIID": "36", "GIL": "3", "GIN": "绵掌", "GIM": "掌力如绵里藏针，连绵不绝，卸力打力。" },
  { "GIID": "37", "GIL": "3", "GIN": "降魔掌", "GIM": "少林正宗掌法，专克邪魔外道，正气浩然。" },
  { "GIID": "38", "GIL": "3", "GIN": "飘雪穿云掌", "GIM": "峨眉掌法，掌风如雪花飘落，穿云破雾。" },
  { "GIID": "39", "GIL": "3", "GIN": "大手印", "GIM": "西域密宗武学，掌力雄浑，势大力沉。" },
  { "GIID": "40", "GIL": "3", "GIN": "混元掌", "GIM": "混元功配套掌法，掌力浑圆一体，无懈可击。" },
  { "GIID": "41", "GIL": "3", "GIN": "三花聚顶掌", "GIM": "道家上乘掌法，精气神三花聚顶，威力倍增。" },
  { "GIID": "42", "GIL": "3", "GIN": "天罗地网掌", "GIM": "古墓派掌法，掌影织成罗网，让敌人无处可逃。" },
  { "GIID": "43", "GIL": "3", "GIN": "白驼掌法", "GIM": "欧阳克家传，阴毒狠辣，配合蛇阵。" },
  { "GIID": "44", "GIL": "3", "GIN": "千手如来掌", "GIM": "招式繁复，如千手观音，令人防不胜防。" },
  { "GIID": "45", "GIL": "4", "GIN": "铁掌", "GIM": "裘千仞绝学，威力不在降龙之下，铁掌水上漂。" },
  { "GIID": "46", "GIL": "4", "GIN": "落英神剑掌", "GIM": "黄药师所创，掌影如落英缤纷，虚实难测。" },
  { "GIID": "47", "GIL": "4", "GIN": "化骨绵掌", "GIM": "蛇岛武功，掌力阴柔，中者骨骼尽碎，化于无形。" },
  { "GIID": "48", "GIL": "4", "GIN": "玄女掌法", "GIM": "古墓派秘传，轻盈灵动，克制全真武功。" },
  { "GIID": "49", "GIL": "4", "GIN": "雷霆八卦掌", "GIM": "八卦掌极致，掌力如雷霆万钧，迅捷猛烈。" },
  { "GIID": "50", "GIL": "4", "GIN": "九宫神行掌", "GIM": "步掌合一，穿梭九宫，让人眼花缭乱。" },
  { "GIID": "51", "GIL": "4", "GIN": "寒冰绵掌", "GIM": "韦一笑所用，阴寒掌力，中者周身结冰。" },
  { "GIID": "52", "GIL": "4", "GIN": "翻天掌", "GIM": "崆峒派绝学，掌力翻覆，颠倒乾坤。" },
  { "GIID": "53", "GIL": "4", "GIN": "般若掌", "GIM": "少林七十二绝技，掌含佛法，慈悲中蕴含杀机。" },
  { "GIID": "54", "GIL": "4", "GIN": "摧心掌", "GIM": "常遇春所学，掌力透胸，震碎心脉。" },
  { "GIID": "55", "GIL": "4", "GIN": "抽髓掌", "GIM": "阴毒掌法，中者骨髓如被抽空，无力而亡。" },
  { "GIID": "56", "GIL": "5", "GIN": "降龙十八掌", "GIM": "天下阳刚第一，郭靖以此扬名，丐帮镇帮神功。" },
  { "GIID": "57", "GIL": "5", "GIN": "黯然销魂掌", "GIM": "杨过自创，心意既伤，掌力亦黯然，威力无穷。" },
  { "GIID": "58", "GIL": "5", "GIN": "惊神掌", "GIM": "梁羽生后期作品中顶级掌功，含雷电之意。" },
  { "GIID": "59", "GIL": "5", "GIN": "天山六阳掌", "GIM": "逍遥派绝学，童姥以此化解生死符，刚柔并济。" },
  { "GIID": "60", "GIL": "5", "GIN": "玄冥神掌", "GIM": "鹤笔翁与鹿杖客绝学，阴毒无比，寒气透骨。" },
  { "GIID": "61", "GIL": "5", "GIN": "火焰刀", "GIM": "鸠摩智绝技，以内力化作刀气伤人，无形无影。" },
  { "GIID": "62", "GIL": "5", "GIN": "大金刚掌", "GIM": "少林七十二绝技之首，刚猛无俦，碎石裂碑。" },
  { "GIID": "63", "GIL": "5", "GIN": "七断七绝伤心掌", "GIM": "古龙笔下，掌力断肠裂肺，伤心断脉。" },
  { "GIID": "64", "GIL": "5", "GIN": "灭仙掌", "GIM": "传说中灭杀仙人，掌力霸道，不可一世。" },
  { "GIID": "65", "GIL": "5", "GIN": "大须弥式掌法", "GIM": "少林至高掌法，掌力大如须弥山，镇压一切。" },
  { "GIID": "66", "GIL": "5", "GIN": "一拍二散", "GIM": "张三丰所创太极十三式之一，掌力一出，敌我皆散。" },
  { "GIID": "99", "GIL": "6", "GIN": "如来神掌", "GIM": "佛祖降世，一掌从天而降，烈火焚身，妖魔俱灭。" }
]