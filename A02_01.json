[
  {
    "GIID": "1",
    "GIL": "0",
    "GIN": "牵牛花",
    "GIM": "晨曦初露吹喇叭，攀援而上，乃凡品中最常见之野趣。"
  },
  {
    "GIID": "2",
    "GIL": "0",
    "GIN": "白菊",
    "GIM": "孤标傲世偕谁隐，寒霜独开，花中隐逸者也。"
  },
  {
    "GIID": "3",
    "GIL": "0",
    "GIN": "蒲公英",
    "GIM": "随风飘散落天涯，落地生根，虽为凡草亦有其志。"
  },
  {
    "GIID": "4",
    "GIL": "0",
    "GIN": "鸡冠花",
    "GIM": "状若雄鸡昂首立，经秋不萎，庭院之中别有风味。"
  },
  {
    "GIID": "5",
    "GIL": "0",
    "GIN": "迎春花",
    "GIM": "金英翠萼带春寒，黄花满枝，最先报得春消息。"
  },
  {
    "GIID": "6",
    "GIL": "0",
    "GIN": "蝴蝶花",
    "GIM": "形似彩蝶舞翩跹，点缀篱下，虽无香亦能动人。"
  },
  {
    "GIID": "7",
    "GIL": "0",
    "GIN": "满天星",
    "GIM": "万千星辰落凡尘，细碎洁白，甘为配角衬群芳。"
  },
  {
    "GIID": "8",
    "GIL": "0",
    "GIN": "千日红",
    "GIM": "经久不退枝头色，繁花如火，象征恒久不变之心。"
  },
  {
    "GIID": "9",
    "GIL": "0",
    "GIN": "马蹄莲",
    "GIM": "素洁高雅形如蹄，清简如水，厅堂摆放显端庄。"
  },
  {
    "GIID": "10",
    "GIL": "0",
    "GIN": "茉莉花",
    "GIM": "虽无艳态惊群目，芳香压酒，熏得一室俱清芬。"
  },
  {
    "GIID": "11",
    "GIL": "0",
    "GIN": "阿拉伯婆婆纳",
    "GIM": "蓝星点点缀田间，生生不息，乃顽强生命之象征。"
  },
  {
    "GIID": "16",
    "GIL": "1",
    "GIN": "月季",
    "GIM": "四季开花不断绝，红颜常驻，中品之花独领风骚。"
  },
  {
    "GIID": "17",
    "GIL": "1",
    "GIN": "石榴花",
    "GIM": "如火如荼燃盛夏，籽多房大，寓意多子多福之家。"
  },
  {
    "GIID": "18",
    "GIL": "1",
    "GIN": "桃花",
    "GIM": "桃之夭夭灼其华，春色满园，人间烟火最浓之处。"
  },
  {
    "GIID": "19",
    "GIL": "1",
    "GIN": "桂花",
    "GIM": "叶密千层秀，花开万点金，秋风一吹香飘十里。"
  },
  {
    "GIID": "20",
    "GIL": "1",
    "GIN": "一串红",
    "GIM": "红焰如瀑挂庭前，蜂蝶环绕，喜庆热烈之色也。"
  },
  {
    "GIID": "21",
    "GIL": "1",
    "GIN": "三角梅",
    "GIM": "苞片似花花非花，热情奔放，南国风情之代表。"
  },
  {
    "GIID": "22",
    "GIL": "1",
    "GIN": "水仙花",
    "GIM": "凌波仙子生尘袜，水上轻盈，案头清供之佳品。"
  },
  {
    "GIID": "23",
    "GIL": "1",
    "GIN": "美人蕉",
    "GIM": "叶绿如蕉花胜火，体态丰腴，夏日庭院之骄子。"
  },
  {
    "GIID": "24",
    "GIL": "1",
    "GIN": "向日葵",
    "GIM": "更无柳絮因风起，惟有葵花，向日倾心志不移。"
  },
  {
    "GIID": "25",
    "GIL": "1",
    "GIN": "康乃馨",
    "GIM": "层层叠叠寄深情，温馨素雅，母爱之花的代名词。"
  },
  {
    "GIID": "26",
    "GIL": "1",
    "GIN": "忘忧草",
    "GIM": "焉得谖草言树之，以此忘忧，食之令人心欢畅。"
  },
  {
    "GIID": "31",
    "GIL": "2",
    "GIN": "芍药",
    "GIM": "自古风流芍药花，娇柔妩媚，花相之名不负卿。"
  },
  {
    "GIID": "32",
    "GIL": "2",
    "GIN": "紫罗兰",
    "GIM": "幽香淡淡透窗纱，神秘高贵，奇品之中藏雅致。"
  },
  {
    "GIID": "33",
    "GIL": "2",
    "GIN": "紫荆花",
    "GIM": "满条红紫簇拥生，骨肉相连，兄弟和睦之象征。"
  },
  {
    "GIID": "34",
    "GIL": "2",
    "GIN": "海棠",
    "GIM": "嫣然一笑竹篱间，胭脂点点，富贵满堂之吉兆。"
  },
  {
    "GIID": "35",
    "GIL": "2",
    "GIN": "荷花",
    "GIM": "出淤泥而不染尘，濯清涟而不妖，花中君子也。"
  },
  {
    "GIID": "36",
    "GIL": "2",
    "GIN": "百合花",
    "GIM": "百年好合永相依，香气袭人，纯洁庄严之典范。"
  },
  {
    "GIID": "37",
    "GIL": "2",
    "GIN": "天堂鸟",
    "GIM": "形如飞鸟欲冲天，姿态奇特，自由翱翔之寓也。"
  },
  {
    "GIID": "38",
    "GIL": "2",
    "GIN": "杜鹃花",
    "GIM": "杜鹃啼血染成花，漫山红遍，映山红遍春意浓。"
  },
  {
    "GIID": "39",
    "GIL": "2",
    "GIN": "栀子花",
    "GIM": "雪魄冰花凉气清，香飘庭院，夏夜清凉之伴侣。"
  },
  {
    "GIID": "40",
    "GIL": "2",
    "GIN": "风信子",
    "GIM": "密集小球聚成塔，五彩斑斓，重生之花寓希望。"
  },
  {
    "GIID": "41",
    "GIL": "2",
    "GIN": "绣球",
    "GIM": "团圞锦簇似绣球，花团紧簇，圆满团聚之寓意。"
  },
  {
    "GIID": "61",
    "GIL": "3",
    "GIN": "梅花",
    "GIM": "已是悬崖百丈冰，犹有花枝俏，凌寒独放之铁骨。"
  },
  {
    "GIID": "62",
    "GIL": "3",
    "GIN": "睡莲",
    "GIM": "昼舒夜卷随日光，水中女神，静卧清波之灵物。"
  },
  {
    "GIID": "63",
    "GIL": "3",
    "GIN": "鸢尾花",
    "GIM": "彩虹坠落凡间化，剑叶刚劲，自由与力量的化身。"
  },
  {
    "GIID": "64",
    "GIL": "3",
    "GIN": "玫瑰",
    "GIM": "带刺红妆不畏人，爱之宣言，珍品之中最炽烈。"
  },
  {
    "GIID": "65",
    "GIL": "3",
    "GIN": "虞美人",
    "GIM": "轻盈起舞弄腰肢，楚楚动人，霸王别姬之凄美。"
  },
  {
    "GIID": "67",
    "GIL": "3",
    "GIN": "茶花",
    "GIM": "雪里开花到春晚，耐久红妆，艳而不妖之贞静。"
  },
  {
    "GIID": "68",
    "GIL": "3",
    "GIN": "彼岸花",
    "GIM": "花开无叶叶无花，生死两隔，黄泉路上的引路灯。"
  },
  {
    "GIID": "69",
    "GIL": "3",
    "GIN": "樱花",
    "GIM": "昨日雪如花，今日花如雪，刹那绚烂之无常美。"
  },
  {
    "GIID": "70",
    "GIL": "3",
    "GIN": "芙蓉",
    "GIM": "晓妆如玉暮如霞，一日三变，拒霜之姿甚是奇。"
  },
  {
    "GIID": "71",
    "GIL": "3",
    "GIN": "薰衣草",
    "GIM": "紫色海洋随风漾，梦幻浪漫，等待爱情的守望者。"
  },
  {
    "GIID": "72",
    "GIL": "3",
    "GIN": "夜来香",
    "GIM": "入夜清香发，随风潜入梦，月下美人之私语。"
  },
  {
    "GIID": "75",
    "GIL": "4",
    "GIN": "兰花",
    "GIM": "空谷幽兰独自香，不因无人而不芳，花中真君子。"
  },
  {
    "GIID": "76",
    "GIL": "4",
    "GIN": "牡丹",
    "GIM": "唯有牡丹真国色，花开时节动京城，花中之王也。"
  },
  {
    "GIID": "77",
    "GIL": "4",
    "GIN": "大王花",
    "GIM": "巨花腐臭招蝇蝶，寄生而生，世界之最的奇观。"
  },
  {
    "GIID": "78",
    "GIL": "4",
    "GIN": "藏红花",
    "GIM": "三根雌蕊贵如金，药食同源，红色黄金之称谓。"
  },
  {
    "GIID": "79",
    "GIL": "4",
    "GIN": "十八学士",
    "GIM": "一株能开十八色，花团锦簇，茶花极品之变异。"
  },
  {
    "GIID": "80",
    "GIL": "4",
    "GIN": "尸花",
    "GIM": "巨花绽放如恶魔，散发腐臭，生命禁区的诱惑。"
  },
  {
    "GIID": "81",
    "GIL": "4",
    "GIN": "铁树花",
    "GIM": "千年铁树今始开，雄花似塔，祥瑞之兆极罕见。"
  },
  {
    "GIID": "82",
    "GIL": "4",
    "GIN": "郁金香",
    "GIM": "杯状酒盏承露珠，高贵典雅，荷兰国花之荣耀。"
  },
  {
    "GIID": "83",
    "GIL": "4",
    "GIN": "腊梅",
    "GIM": "枝横碧玉天然瘦，蕊破黄金分外香，寒冬之傲骨。"
  },
  {
    "GIID": "84",
    "GIL": "4",
    "GIN": "帝王花",
    "GIM": "硕大花球如皇冠，久开不败，王者之尊的象征。"
  },
  {
    "GIID": "85",
    "GIL": "4",
    "GIN": "昙花",
    "GIM": "刹那芬芳留余香，月下美人，只为韦陀一现身。"
  },
  {
    "GIID": "91",
    "GIL": "5",
    "GIN": "朱丽叶玫瑰",
    "GIM": "价值千万的奥斯汀，圆润如包，切花中的奢侈品。"
  },
  {
    "GIID": "92",
    "GIL": "5",
    "GIN": "睡火莲",
    "GIM": "紫色花瓣裹金蕊，仅开七日，格兰蒂亚的圣物。"
  },
  {
    "GIID": "93",
    "GIL": "5",
    "GIN": "嘉兰百合",
    "GIM": "花瓣反卷如火焰，妖冶诡异，花中独特的异类。"
  },
  {
    "GIID": "94",
    "GIL": "5",
    "GIN": "鬼兰",
    "GIM": "风中摇晃似幽灵，无叶无土，附生空气中的鬼魅。"
  },
  {
    "GIID": "95",
    "GIL": "5",
    "GIN": "九穗禾",
    "GIM": "传说嘉禾生九穗，食之可长生，上古仙界之遗珠。"
  },
  {
    "GIID": "96",
    "GIL": "5",
    "GIN": "斯里兰卡仙人掌花",
    "GIM": "深夜绽放难捕捉，洁白如雪，极为罕见的幽灵花。"
  },
  {
    "GIID": "97",
    "GIL": "5",
    "GIN": "曼珠沙华",
    "GIM": "彼岸花开开彼岸，花开叶落永不见，黄泉路上的指引。"
  }
]